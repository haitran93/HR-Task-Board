# Copy this file to .env (root, for scripts/seed.mjs) — never commit the real .env.
# IMPORTANT: wrap PASSCODE_* values in double quotes. Node's --env-file treats an
# unquoted `#` as a comment even mid-value, which silently truncates any passcode
# containing `#` (bit us once already — see scripts/seed.mjs's password-sync comment).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PASSCODE_HAITT5=""
PASSCODE_THYNX=""
PASSCODE_PHUONGNNX=""
PASSCODE_ANHPTL=""
PASSCODE_NHANLTP=""
PASSCODE_TRANGPTT12=""
PASSCODE_VING=""
